@page
@model RegisterModel

@{
    ViewData["Title"] = "Регистрация";
}

<div class="container d-flex justify-content-center">
    <div class="col-md-8">

        <h2 class="text-center mb-4">Регистрация</h2>

        <form id="registerForm"
              asp-route-returnUrl="@Model.ReturnUrl"
              method="post">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3"
                 role="alert"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <div class="form-floating">
                        <input asp-for="Input.UserName"
                               class="form-control"
                               placeholder="Потребителско име" />

                        <label asp-for="Input.UserName">
                            Потребителско име
                        </label>

                        <span asp-validation-for="Input.UserName"
                              class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <div class="form-floating">
                        <input asp-for="Input.Email"
                               class="form-control"
                               placeholder="Имейл" />

                        <label asp-for="Input.Email">
                            Имейл
                        </label>

                        <span asp-validation-for="Input.Email"
                              class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <div class="form-floating">
                        <input asp-for="Input.FirstName"
                               class="form-control"
                               placeholder="Име" />

                        <label asp-for="Input.FirstName">
                            Име
                        </label>

                        <span asp-validation-for="Input.FirstName"
                              class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <div class="form-floating">
                        <input asp-for="Input.LastName"
                               class="form-control"
                               placeholder="Фамилия" />

                        <label asp-for="Input.LastName">
                            Фамилия
                        </label>

                        <span asp-validation-for="Input.LastName"
                              class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <div class="form-floating">
                        <input asp-for="Input.PhoneNumber"
                               class="form-control"
                               placeholder="Телефон" />

                        <label asp-for="Input.PhoneNumber">
                            Телефон
                        </label>

                        <span asp-validation-for="Input.PhoneNumber"
                              class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <div class="form-floating">
                        <input asp-for="Input.Password"
                               type="password"
                               class="form-control"
                               placeholder="Парола" />

                        <label asp-for="Input.Password">
                            Парола
                        </label>

                        <span asp-validation-for="Input.Password"
                              class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6 mx-auto mb-3">
                    <div class="form-floating">
                        <input asp-for="Input.ConfirmPassword"
                               type="password"
                               class="form-control"
                               placeholder="Потвърди парола" />

                        <label asp-for="Input.ConfirmPassword">
                            Потвърди парола
                        </label>

                        <span asp-validation-for="Input.ConfirmPassword"
                              class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="text-center">
                <button id="registerSubmit"
                        type="submit"
                        class="btn btn-primary px-5">
                    Регистрация
                </button>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
