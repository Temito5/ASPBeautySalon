    <style>

        .contacts-page {
            background: #f3f3f3;
            color: #1f1f1f;
            font-family: 'Segoe UI',Arial,sans-serif;
            padding-bottom: 70px;
        }

        /* TABS */

        .salon-tabs {
            max-width: 980px;
            margin: 70px auto 25px auto;
            display: flex;
            justify-content: center;
            gap: 14px;
            flex-wrap: wrap;
        }

        .salon-tab {
            padding: 14px 28px;
            border-radius: 40px;
            border: 1px solid #cdb79a;
            background: #fff;
            color: #5c4630;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.25s ease;
        }

            .salon-tab:hover {
                background: #f8f1e8;
                border-color: #9a7440;
                color: #9a7440;
            }

            .salon-tab.active {
                background: #9a7440;
                color: #fff;
                border-color: #9a7440;
            }

        /* PANELS */

        .contact-info-panel {
            max-width: 1420px;
            min-height: 360px;
            margin: 0 auto 90px auto;
            background: #fff;
            border: 1px solid #d6d6d6;
            /* ДОБАВИ ТОВА */
            border-radius: 32px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.06);
            padding: 50px 30px;
            display: none;
            grid-template-columns: repeat(3,1fr);
            align-items: center;
            text-align: center;
        }

            .contact-info-panel.active {
                display: grid;
            }

        .info-icon {
            margin-bottom: 18px;
            color: #9a7440;
            font-size: 70px;
            line-height: 1;
        }

        .info-column h3 {
            margin: 0 0 14px 0;
            font-size: 27px;
            letter-spacing: 3px;
            font-weight: 800;
        }

        .info-column p {
            margin: 5px 0;
            color: #4d5a6a;
            font-size: 22px;
            line-height: 1.45;
        }

        /* MOBILE */

        @@media (max-width:1100px) {

            .contact-info-panel {
                grid-template-columns: 1fr;
                gap: 55px;
            }

            .salon-tabs {
                flex-direction: column;
                margin-left: 20px;
                margin-right: 20px;
            }
        }

        @@media (max-width:650px) {

            .salon-tab {
                font-size: 16px;
                padding: 16px;
            }

            .contact-info-panel {
                padding: 45px 20px;
            }

            .info-column p {
                font-size: 18px;
            }
        }

        .contact-form-section {
            max-width: 1540px;
            margin: 0 auto 85px auto;
            display: grid;
            grid-template-columns: 1fr 0.95fr;
            gap: 0;
            align-items: start;
        }

        .contact-left {
            padding: 0 25px;
        }

        .small-title {
            display: block;
            margin-bottom: 20px;
            font-size: 50px;
            text-align:center;
            letter-spacing: 1px;
        }

        .contact-left h1 {
            margin: 0 0 28px 0;
            font-size: 70px;
            line-height: 1;
            font-weight: 900;
            letter-spacing: -3px;
        }

        .contact-left p {
            max-width: 620px;
            margin-bottom: 55px;
            color: #667080;
            font-size: 24px;
            line-height: 1.55;
        }

        .contact-image {
            width: 100%;
            height: 560px;
            object-fit: cover;
            display: block;
        }

        .contact-form-box {
            background: #fff;
            padding: 90px 85px;
            min-height: 610px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 38px;
            margin-bottom: 42px;
        }

        .input-box {
            display: flex;
            align-items: center;
            gap: 16px;
            border-bottom: 1px solid #bfb7ae;
            padding-bottom: 15px;
            color: #a7a7a7;
        }

            .input-box span {
                font-size: 28px;
                color: #a8a8a8;
            }

            .input-box input, .input-box textarea {
                width: 100%;
                border: none;
                outline: none;
                color: #333;
                font-size: 21px;
                background: transparent;
            }

                .input-box input::placeholder, .input-box textarea::placeholder {
                    color: #a5a5ad;
                }

        .textarea-box {
            align-items: flex-start;
            margin-top: 25px;
            margin-bottom: 60px;
        }

            .textarea-box textarea {
                height: 95px;
                resize: none;
            }

        .privacy-row {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            color: #606a76;
            font-size: 19px;
            line-height: 1.45;
        }

            .privacy-row input {
                width: 20px;
                height: 20px;
                margin-top: 4px;
            }

        .send-btn {
            margin-top: 48px;
            padding: 20px 43px;
            border: none;
            border-radius: 35px;
            background: #f6b14d;
            color: #fff;
            font-size: 22px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.25s ease;
        }

            .send-btn:hover {
                background: #d9983b;
                transform: translateY(-2px);
            }

        .maps-section {
            max-width: 1720px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 70px;
            padding: 0 20px;
        }

        .map-item h2 {
            text-align: center;
            margin-bottom: 32px;
            font-size: 28px;
            font-weight: 800;
        }

        .map-frame {
            padding: 24px;
            border: 1px solid #9a7440;
            background: #fffaf6;
        }

            .map-frame iframe {
                display: block;
            }

        @@media (max-width: 1100px) {
            .contact-info-panel, .contact-form-section, .maps-section {
                grid-template-columns: 1fr;
            }

            .contact-info-panel {
                gap: 55px;
            }

            .salon-tabs {
                flex-direction: column;
                margin-left: 20px;
                margin-right: 20px;
            }

            .contact-left h1 {
                font-size: 52px;
            }

            .contact-form-box {
                padding: 55px 35px;
            }
        }

        @@media (max-width: 650px) {
            .salon-tab {
                font-size: 18px;
                padding: 18px;
            }

            .contact-info-panel {
                padding: 45px 20px;
            }

            .info-column p {
                font-size: 18px;
            }

            .form-row {
                grid-template-columns: 1fr;
            }

            .contact-left h1 {
                font-size: 42px;
            }

            .contact-left p {
                font-size: 19px;
            }

            .contact-image {
                height: 360px;
            }

            .map-frame {
                padding: 12px;
            }

                .map-frame iframe {
                    height: 360px;
                }
        }
    </style>

    <script>

        function showSalon(id, element){

            // маха active от табовете
            document.querySelectorAll('.salon-tab')
                .forEach(tab => tab.classList.remove('active'));

            // active на натиснатия таб
            element.classList.add('active');

            // скрива всички панели
            document.querySelectorAll('.contact-info-panel')
                .forEach(panel => panel.classList.remove('active'));

            // показва избрания
            document.getElementById(id)
                .classList.add('active');
        }

    </script>
