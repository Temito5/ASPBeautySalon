@{
    ViewData["Title"] = "За нас";
}
<section class="hero-video">
    <video autoplay muted loop playsinline class="bg-video">
        <source src="/video/spa.mp4" type="video/mp4">
    </video>
    <div class="overlay"></div>

    <div class="content-video">
        <p class="subtitle">Цветен блясък</p>

        <h1>
            Красота, стил<br>
            и професионална грижа
        </h1>

        <p class="description">
            Подарете си релакс и самочувствие
            с нашите професионални процедури.
        </p>

        <a class="hero-btn"
           asp-controller="Reservations"
           asp-action="Create">
            Запази час
        </a>
    </div>
</section>
<section class="about-section">
    <div class="container">
       
    <!-- ЗАГЛАВИЕ -->
    

    <!-- ТЕКСТ (НАД ВИДЕОТО) -->
    <div class="about-text-block">

        <h2 class="about-subtitle">Доверете се на естествената красота</h2>

        <p>
            Добре дошли в Салон за красота „Цветен блясък“ – мястото, където грижата за външния вид се превръща в истинско изживяване. От самото начало нашата мисия е да създадем пространство, в което всеки клиент се чувства специален, спокоен и уверен в себе си.
        </p>

        
        <p class="about-last">
            Очакваме Ви, за да се погрижим за Вашата визия и добро настроение.
        </p>

    </div>

    <!-- ВИДЕО -->
       

    <!-- СНИМКИ -->
    <div class="gallery">
        <img src="/images/makeups.png" />
        <img src="/images/manicur.png" />
        <img src="/images/masage.png" />
        <img src="/images/pedicur.png" />
        <img src="/images/hairdresser.png" />
        <img src="/images/lasser.png" />
    </div>

</div>
</section>
