@model IEnumerable<ASPBeautySalon.Models.Category>

@{
    ViewData["Title"] = "Категории";
}

<div class="categories-page">

    <section class="categories-hero">

        <div class="categories-header">

            <div>

                <span class="page-tag">Цветен Блясък</span>

                <h1 class="categories-title">
                    Категории услуги
                </h1>

                <p class="categories-subtitle">
                    Управление на всички категории в салона.
                </p>

            </div>

            <a asp-action="Create" class="btn-create">
                + Нова категория
            </a>

        </div>

    </section>

    <section class="categories-wrapper">

        <div class="categories-grid">

            @foreach (var item in Model)
            {
                <div class="category-card">

                    <div class="category-icon">
                        📁
                    </div>

                    <div class="category-name">
                        @item.Name
                    </div>

                    <div class="category-desc">
                        @item.Description
                    </div>

                    <div class="category-date">
                        📅 @item.DateRegOn.ToString("dd.MM.yyyy")
                    </div>

                    <div class="category-actions">

                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn-cat btn-edit">
                            Редактирай
                        </a>

                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn-cat btn-details">
                            Детайли
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn-cat btn-delete">
                            Изтрий
                        </a>

                    </div>

                </div>
            }

        </div>

    </section>

</div>