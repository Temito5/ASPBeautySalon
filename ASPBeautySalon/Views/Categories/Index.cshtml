@model IEnumerable<ASPBeautySalon.Models.Category>

@{
    ViewData["Title"] = "Категории";
}

<div class="categories-page">

    <!-- HERO -->
    <section class="categories-hero">

        <div class="categories-header">

            <div>

                <span class="page-tag">BEAUTY SALON</span>

                <h1 class="categories-title">
                    Категории услуги
                </h1>

                <p class="categories-subtitle">
                    Управление на всички категории в салона.
                </p>

            </div>

            <a asp-action="Create" class="btn-create">
                + Нова категория
            </a>

        </div>

    </section>

    <!-- GRID -->
    <section class="categories-wrapper">

        <div class="categories-grid">

            @foreach (var item in Model)
            {
                <div class="category-card">

                    <!-- ICON -->
                    <div class="category-icon">
                        📁
                    </div>

                    <!-- NAME -->
                    <div class="category-name">
                        @item.Name
                    </div>

                    <!-- DESCRIPTION -->
                    <div class="category-desc">
                        @item.Description
                    </div>

                    <!-- DATE -->
                    <div class="category-date">
                        📅 @item.DateRegOn.ToString("dd.MM.yyyy")
                    </div>

                    <!-- ACTIONS -->
                    <div class="category-actions">

                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn-cat btn-edit">
                            Edit
                        </a>

                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn-cat btn-details">
                            Details
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn-cat btn-delete">
                            Delete
                        </a>

                    </div>

                </div>
            }

        </div>

    </section>

</div>

<style>

    /* ===== BASE ===== */

    :root {
        --bg: #f3eee8;
        --hero: #f7f2ec;
        --card: #ffffff;
        --gold: #c7a03d;
        --text: #2d2118;
        --soft: #6f7684;
        --border: #eadfce;
    }

    /* PAGE */

    .categories-page {
        background: var(--bg);
        min-height: 100vh;
        padding: 60px 40px 100px;
        font-family: 'Segoe UI', sans-serif;
    }

    /* HERO */

    .categories-hero {
        max-width: 1650px;
        margin: auto;
        background: var(--hero);
        border-radius: 40px;
        padding: 70px;
        border: 1px solid var(--border);
        box-shadow: 0 12px 35px rgba(0,0,0,0.06);
    }

    .categories-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .page-tag {
        color: var(--gold);
        font-weight: 800;
        letter-spacing: 3px;
        font-size: 14px;
    }

    .categories-title {
        font-size: 64px;
        font-weight: 900;
        color: var(--text);
        margin: 10px 0 15px;
    }

    .categories-subtitle {
        color: var(--soft);
        font-size: 20px;
    }

    /* BUTTON */

    .btn-create {
        padding: 18px 36px;
        border-radius: 50px;
        background: linear-gradient(135deg, #e3bf58, #c7a03d);
        color: #2f241b;
        font-weight: 800;
        text-decoration: none;
        box-shadow: 0 10px 25px rgba(199,160,61,0.25);
        transition: 0.3s;
    }

        .btn-create:hover {
            transform: translateY(-3px);
            background: linear-gradient(135deg, #a8842f, #c7a03d);
            color: #fff;
        }

    /* GRID */

    .categories-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 25px;
        margin-top: 40px;
    }

    /* CARD */

    .category-card {
        background: var(--card);
        border-radius: 25px;
        padding: 25px;
        border: 1px solid var(--border);
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        transition: 0.3s;
    }

        .category-card:hover {
            transform: translateY(-6px);
        }

    /* ICON */

    .category-icon {
        width: 55px;
        height: 55px;
        border-radius: 16px;
        background: #f7f1e5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: var(--gold);
        margin-bottom: 15px;
    }

    /* TEXT */

    .category-name {
        font-size: 20px;
        font-weight: 900;
        color: var(--text);
    }

    .category-desc {
        margin-top: 10px;
        font-size: 15px;
        color: var(--soft);
        min-height: 40px;
    }

    /* DATE */

    .category-date {
        margin-top: 12px;
        font-size: 13px;
        color: var(--soft);
    }

    /* ACTIONS */

    .category-actions {
        margin-top: 15px;
        display: flex;
        gap: 8px;
    }

    /* BUTTONS */

    .btn-cat {
        flex: 1;
        text-align: center;
        padding: 10px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
    }

    /* EDIT */

    .btn-edit {
        background: #f5efe4;
        color: #8f6b3f;
    }

        .btn-edit:hover {
            background: #e7d5b7;
        }

    /* DETAILS */

    .btn-details {
        background: #ececec;
        color: #333;
    }

        .btn-details:hover {
            background: #dcdcdc;
        }

    /* DELETE */

    .btn-delete {
        background: #fff0f0;
        color: #c14f4f;
    }

        .btn-delete:hover {
            background: #ffdcdc;
        }

    /* RESPONSIVE */

    @@media(max-width:900px) {

        .categories-title {
            font-size: 38px;
        }

        .categories-hero {
            padding: 30px;
        }
    }
</style>