@model ASPBeautySalon.Models.Reservation

@{
    ViewData["Title"] = "Детайли на резервация";
}

<div class="details-page">

    <section class="details-hero">

        <div class="details-header">

            <div>

                <span class="page-tag">Детайли на резервация</span>

                <h1 class="details-title">
                    Резервация
                </h1>

                <p class="details-subtitle">
                    Пълна информация за избраната резервация
                </p>

            </div>

            <a asp-action="Index" class="btn-back">
                Назад
            </a>

        </div>

    </section>

    <section class="details-wrapper">

        <div class="details-card">

            <div class="details-item">

                <div class="icon">✂</div>

                <div>
                    <div class="label">Услуга</div>
                    <div class="value">
                        @Model.Services?.Name
                    </div>
                </div>

            </div>

            <div class="details-item">

                <div class="icon">👤</div>

                <div>
                    <div class="label">Клиент</div>
                    <div class="value">
                        @Model.Clients?.UserName
                    </div>
                </div>

            </div>

            <div class="details-item">

                <div class="icon">📅</div>

                <div>
                    <div class="label">Дата на резервация</div>
                    <div class="value">
                        @Model.DateReservation.ToString("dd.MM.yyyy HH:mm")
                    </div>
                </div>

            </div>

            <div class="details-item">

                <div class="icon">🕒</div>

                <div>
                    <div class="label">Създадена на</div>
                    <div class="value">
                        @Model.DateRegOn.ToString("dd.MM.yyyy")
                    </div>
                </div>

            </div>

        </div>

    </section>

</div>
