@model IEnumerable<ASPBeautySalon.Models.Reservation>

@{
    ViewData["Title"] = "Поръчки";
}

<div class="reservations-page">

    <section class="reservations-hero">

        <div class="reservations-header">

            <div>

                <span class="page-tag">Цветен блясък</span>

                <h1 class="reservations-title">
                    Резервации
                </h1>

                <p class="reservations-subtitle">
                    Преглед на всички резервации в системата.
                </p>

            </div>

        </div>

    </section>

    <section class="reservations-wrapper">

        <div class="reservations-card">

            @if (Model != null && Model.Any())
            {
                <div class="reservations-grid">

                    @foreach (var item in Model)
                    {
                        <div class="reservation-card">

                            <div class="card-top">

                                <div class="service-icon">✂</div>

                                <div>
                                    <div class="service-name">
                                        @item.Services?.Name
                                    </div>
                                </div>

                            </div>

                            <div class="card-client">
                                👤 @item.Clients?.UserName
                            </div>

                            <div class="card-datetime">

                                <div class="date">
                                    📅 @item.DateReservation.ToString("dd.MM.yyyy")
                                </div>

                                <div class="time">
                                    ⏰ @item.DateReservation.ToString("HH:mm")
                                </div>

                            </div>

                            <div class="card-created">
                                Създадена: @item.DateRegOn.ToString("dd.MM.yyyy")
                            </div>

                            <div class="card-actions">

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn-details-full">
                                    Детайли
                                </a>

                            </div>

                        </div>
                    }

                </div>
            }
            else
            {
                <div class="empty-reservations">

                    <div class="empty-icon">✨</div>

                    <h3>Няма резервации</h3>

                    <p>Все още няма добавени записи.</p>

                </div>
            }

        </div>

    </section>

</div>
